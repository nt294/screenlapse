#!/bin/bash
set -e

INTERVAL=1
OUTDIR=""
WIDTH=1280
DISPLAY_FLAG=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i|--interval) INTERVAL="$2"; shift 2 ;;
        -dir|--directory) OUTDIR="$2"; shift 2 ;;
        -w|--width)    WIDTH="$2";    shift 2 ;;
        -d|--display)  DISPLAY_FLAG="-D $2"; shift 2 ;;
        -h|--help)
            printf "Usage: screenlapse [options]\n\n"
            printf "Options:\n"
            printf "  -i, --interval <secs>   Capture interval in seconds (default: 1)\n"
            printf "  -dir, --directory <dir>  Output directory (default: screenlapse_<timestamp>)\n"
            printf "  -w, --width <px>        Output frame width in pixels (default: 1280)\n"
            printf "  -d, --display <n>       Display number to capture (default: current display)\n"
            printf "  -h, --help              Show this help message\n"
            exit 0
            ;;
        *) printf "Unknown option: %s\nUse -h for help.\n" "$1"; exit 1 ;;
    esac
done

OUTDIR="${OUTDIR:-screenlapse_$(date +%Y-%m-%d_%H-%M-%S)}"
OUTDIR="${OUTDIR/#\~/$HOME}"

TMPDIR=$(mktemp -d)
FRAME=0
START=$(gdate +%s%3N 2>/dev/null || python3 -c "import time;print(int(time.time()*1000))")

ms_now() { gdate +%s%3N 2>/dev/null || python3 -c "import time;print(int(time.time()*1000))"; }

cleanup() {
    if [ "$FRAME" -eq 0 ]; then
        printf "\nNo frames captured.\n"
        rm -rf "$TMPDIR"
        exit 0
    fi

    printf "\n\nSaving %d frames to %s/..." "$FRAME" "$OUTDIR"

    python3 - "$TMPDIR" "$OUTDIR" "$WIDTH" <<'PYEOF'
import sys, os, glob
from PIL import Image, ImageDraw, ImageFont

tmpdir, outdir, target_w = sys.argv[1], sys.argv[2], int(sys.argv[3])

LABEL_H = 32
LABEL_BG = (30, 30, 30)
FG = (200, 200, 200)

os.makedirs(outdir, exist_ok=True)

try:
    font = ImageFont.truetype("/System/Library/Fonts/SFCompact.ttf", 18)
except Exception:
    try:
        font = ImageFont.truetype("/System/Library/Fonts/Helvetica.ttc", 18)
    except Exception:
        font = ImageFont.load_default()

frames = sorted(glob.glob(os.path.join(tmpdir, "frame_*.*")))
if not frames:
    print(" no frames found.")
    sys.exit(1)

total_size = 0
for i, f in enumerate(frames):
    img = Image.open(f)
    if img.size[0] != target_w:
        ratio = target_w / img.size[0]
        img = img.resize((target_w, int(img.size[1] * ratio)), Image.LANCZOS)

    frame_w, frame_h = img.size

    # parse elapsed time from filename
    base = os.path.splitext(os.path.basename(f))[0]
    parts = base.split("_")
    elapsed = parts[-1].rstrip("ms") if len(parts) >= 3 else "?"
    elapsed_f = int(elapsed) / 1000 if elapsed.isdigit() else elapsed

    # create image with label bar on top
    out_img = Image.new("RGB", (frame_w, LABEL_H + frame_h), LABEL_BG)
    draw = ImageDraw.Draw(out_img)

    label = f"  Frame {i+1}  —  +{elapsed_f}s"
    draw.text((6, 6), label, fill=FG, font=font)

    out_img.paste(img, (0, LABEL_H))

    out_path = os.path.join(outdir, f"frame_{i+1:03d}_{elapsed_f}s.jpg")
    out_img.save(out_path, "JPEG", quality=90)
    total_size += os.path.getsize(out_path)

mb = total_size / (1024 * 1024)
print(f" saved {len(frames)} frames to {outdir}/ ({mb:.1f}MB total)")
PYEOF

    rm -rf "$TMPDIR"
    exit 0
}

trap cleanup SIGINT SIGTERM

DISPLAY_MSG=""
if [ -n "$DISPLAY_FLAG" ]; then
    DISPLAY_MSG=", display=$(echo $DISPLAY_FLAG | awk '{print $2}')"
fi
printf "Capturing every %ss → %s/ (width=%s%s)\nCtrl+C to stop and save\n\n" "$INTERVAL" "$OUTDIR" "$WIDTH" "$DISPLAY_MSG"

NEXT_MS=$((START))

while true; do
    ELAPSED=$(($(ms_now) - START))
    FRAME=$((FRAME + 1))
    FILENAME=$(printf "frame_%04d_%dms.jpg" "$FRAME" "$ELAPSED")
    screencapture $DISPLAY_FLAG -x -C -t jpg "$TMPDIR/$FILENAME"
    printf "  [%d] +%.1fs\n" "$FRAME" "$(echo "$ELAPSED / 1000" | bc -l)"

    NEXT_MS=$(echo "$NEXT_MS + $INTERVAL * 1000" | bc | cut -d. -f1)
    NOW=$(ms_now)
    REMAIN=$((NEXT_MS - NOW))
    if [ "$REMAIN" -gt 0 ]; then
        sleep "$(echo "scale=3; $REMAIN / 1000" | bc)"
    fi
done
